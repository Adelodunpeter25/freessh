{
  "name": "freessh-ssh-server",
  "version": "1.0.0",
  "description": "SSH backend server for FreeSSH mobile app",
  "main": "dist/server.js",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target node",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "ssh2": "^1.15.0",
    "ws": "^8.18.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.3"
  },
  "keywords": ["ssh", "terminal", "websocket", "freessh"],
  "author": "FreeSSH",
  "license": "MIT"
}
